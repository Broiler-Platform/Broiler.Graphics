<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <!-- Core is platform-neutral, fully safe, trimming/AOT friendly. -->
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <IsTrimmable>true</IsTrimmable>
    <IsAotCompatible>true</IsAotCompatible>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>Broiler.Graphics</RootNamespace>
    <AssemblyName>Broiler.Graphics</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- The test runner reaches selected internals for core graphics coverage. -->
    <InternalsVisibleTo Include="Broiler.Graphics.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Broiler.Media\Broiler.Media.Image.Managed\Broiler.Media.Image.Managed.csproj" />
  </ItemGroup>

</Project>
